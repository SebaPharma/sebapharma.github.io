<script>
    // Reveal on scroll
    const obs = new IntersectionObserver(e => e.forEach(el => { if(el.isIntersecting) el.target.classList.add('active') }), { threshold: 0.1, rootMargin: '0px 0px -5% 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

    // Navbar scroll effect
    const nav = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
        nav.querySelector('.glass').classList.toggle('nav-scrolled', window.scrollY > 60);
    });

    // Mobile menu
    const mm = document.getElementById('mobileMenu');
    document.getElementById('menuToggle').addEventListener('click', () => mm.classList.add('open'));
    document.getElementById('menuClose').addEventListener('click', () => mm.classList.remove('open'));
    document.querySelectorAll('.mobile-link').forEach(l => l.addEventListener('click', () => mm.classList.remove('open')));

    // Counter animation
    const cObs = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if(e.isIntersecting) {
                const el = e.target, t = parseInt(el.dataset.target), d = 2000, s = performance.now();
                (function up(now) {
                    const p = Math.min((now - s) / d, 1), v = Math.floor((1 - Math.pow(1 - p, 4)) * t);
                    el.textContent = v + (t === 98 ? '%' : '+');
                    if(p < 1) requestAnimationFrame(up);
                })(s);
                cObs.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('.counter').forEach(el => cObs.observe(el));

    // Contact form
    document.getElementById('contactForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const m = document.getElementById('formMessage');
        m.className = 'text-center text-sm py-3 rounded-xl bg-pharma-500/20 text-pharma-300 border border-pharma-500/30';
        m.textContent = '✓ Mensaje enviado correctamente. Nos pondremos en contacto pronto.';
        m.classList.remove('hidden');
        setTimeout(() => { m.classList.add('hidden'); this.reset(); }, 5000);
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', function(e) {
            e.preventDefault();
            const t = document.querySelector(this.getAttribute('href'));
            if(t) window.scrollTo({ top: t.getBoundingClientRect().top + window.pageYOffset - 100, behavior: 'smooth' });
        });
    });

    // Hide global decorations on dark sections
    const gDecos = document.getElementById('globalDecos');
    const darkSections = document.querySelectorAll('#contacto, footer');
    const lightSections = document.querySelectorAll('[data-light="true"]');

    function updateDecoVisibility() {
        const scrollY = window.scrollY;
        const windowH = window.innerHeight;
        let inDark = false;

        darkSections.forEach(sec => {
            const top = sec.offsetTop - 80;
            const bottom = top + sec.offsetHeight;
            if(scrollY + windowH > top && scrollY < bottom) inDark = true;
        });

        gDecos.style.opacity = inDark ? '0' : '1';
        gDecos.style.transition = 'opacity 0.6s ease';
    }

    window.addEventListener('scroll', updateDecoVisibility, { passive: true });
    updateDecoVisibility();
</script>
