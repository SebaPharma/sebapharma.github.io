<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SebaPharma — Laboratorio Farmacéutico</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { geist: ['Geist', 'sans-serif'] },
                    colors: {
                        aero: { 50:'#f0f9ff',100:'#e0f2fe',200:'#b9e6fe',300:'#7cd4fd',400:'#36bffa',500:'#0ba5ec',600:'#0086c9',700:'#026aa2',800:'#065986',900:'#0b4a6f',950:'#072f4a' },
                        pharma: { 50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d' },
                    }
                }
            }
        }
    </script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:'Geist',sans-serif;overflow-x:hidden}

        .glass{background:rgba(255,255,255,0.55);backdrop-filter:blur(20px) saturate(1.8);-webkit-backdrop-filter:blur(20px) saturate(1.8);border:1px solid rgba(255,255,255,0.6)}
        .glass-strong{background:rgba(255,255,255,0.75);backdrop-filter:blur(30px) saturate(2);-webkit-backdrop-filter:blur(30px) saturate(2);border:1px solid rgba(255,255,255,0.7)}
        .glass-dark{background:rgba(7,47,74,0.7);backdrop-filter:blur(20px) saturate(1.5);-webkit-backdrop-filter:blur(20px) saturate(1.5);border:1px solid rgba(255,255,255,0.1)}
        .glass-card{background:rgba(255,255,255,0.5);backdrop-filter:blur(16px) saturate(1.6);-webkit-backdrop-filter:blur(16px) saturate(1.6);border:1px solid rgba(255,255,255,0.5);box-shadow:0 8px 32px rgba(0,133,201,0.08),inset 0 1px 0 rgba(255,255,255,0.7)}

        .btn-aero{background:linear-gradient(180deg,rgba(255,255,255,0.25) 0%,rgba(255,255,255,0.05) 100%);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.35);box-shadow:0 4px 16px rgba(0,133,201,0.2),inset 0 1px 0 rgba(255,255,255,0.4);transition:all .4s cubic-bezier(.25,1,.5,1)}
        .btn-aero:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,133,201,0.3),inset 0 1px 0 rgba(255,255,255,0.5)}
        .btn-primary-aero{background:linear-gradient(135deg,#0ba5ec 0%,#0086c9 50%,#026aa2 100%);border:1px solid rgba(255,255,255,0.2);box-shadow:0 4px 20px rgba(0,133,201,0.35),inset 0 1px 0 rgba(255,255,255,0.25);transition:all .4s cubic-bezier(.25,1,.5,1)}
        .btn-primary-aero:hover{transform:translateY(-2px);box-shadow:0 8px 40px rgba(0,133,201,0.45),inset 0 1px 0 rgba(255,255,255,0.3)}

        .aero-bg{background:linear-gradient(160deg,#e0f2fe 0%,#f0f9ff 25%,#dcfce7 50%,#e0f2fe 75%,#f0f9ff 100%);position:relative}

        /* === FLOATING ELEMENTS === */
        .float-el{position:absolute;pointer-events:none;z-index:0;will-change:transform}
        .bubble{border-radius:50%;background:radial-gradient(circle at 30% 30%,rgba(255,255,255,0.85),rgba(54,191,250,0.12));border:1px solid rgba(255,255,255,0.55);box-shadow:inset 0 -4px 12px rgba(0,133,201,0.06),0 4px 20px rgba(0,133,201,0.05)}
        .bubble-sm{border-radius:50%;background:radial-gradient(circle at 30% 30%,rgba(255,255,255,0.9),rgba(54,191,250,0.1));border:1px solid rgba(255,255,255,0.45);box-shadow:inset 0 -2px 6px rgba(0,133,201,0.05)}
        .bubble-xs{border-radius:50%;background:radial-gradient(circle at 35% 30%,rgba(255,255,255,0.95),rgba(54,191,250,0.08));border:1px solid rgba(255,255,255,0.4)}

        .glassy-pill{background:linear-gradient(135deg,rgba(255,255,255,0.6),rgba(54,191,250,0.1));backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.5);box-shadow:inset 0 1px 0 rgba(255,255,255,0.7),0 4px 16px rgba(0,133,201,0.06)}
        .glassy-capsule{background:linear-gradient(90deg,rgba(54,191,250,0.2) 0%,rgba(255,255,255,0.6) 40%,rgba(255,255,255,0.6) 60%,rgba(74,222,128,0.2) 100%);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.5);box-shadow:inset 0 1px 0 rgba(255,255,255,0.7),0 4px 16px rgba(0,133,201,0.06)}
        .glassy-molecule{color:rgba(0,133,201,0.12);filter:drop-shadow(0 2px 8px rgba(0,133,201,0.04))}
        .glassy-microscope{color:rgba(0,133,201,0.1);filter:drop-shadow(0 2px 8px rgba(0,133,201,0.03))}
        .glassy-dna{color:rgba(34,197,94,0.1);filter:drop-shadow(0 2px 8px rgba(34,197,94,0.03))}

        /* Animations */
        @keyframes floatA{0%,100%{transform:translateY(0) translateX(0) rotate(0deg)}25%{transform:translateY(-35px) translateX(18px) rotate(2deg)}50%{transform:translateY(-12px) translateX(-14px) rotate(-1.5deg)}75%{transform:translateY(-28px) translateX(22px) rotate(1deg)}}
        @keyframes floatB{0%,100%{transform:translateY(0) translateX(0) rotate(0deg)}33%{transform:translateY(-22px) translateX(-20px) rotate(-3deg)}66%{transform:translateY(-40px) translateX(12px) rotate(2deg)}}
        @keyframes floatC{0%,100%{transform:translateY(0) translateX(0) rotate(0deg)}20%{transform:translateY(-18px) translateX(25px) rotate(4deg)}50%{transform:translateY(-45px) translateX(-8px) rotate(-2deg)}80%{transform:translateY(-10px) translateX(-18px) rotate(1deg)}}
        @keyframes floatD{0%,100%{transform:translateY(0) translateX(0) rotate(0deg)}40%{transform:translateY(-30px) translateX(-15px) rotate(-2deg)}70%{transform:translateY(-15px) translateX(20px) rotate(3deg)}}
        @keyframes slowSpin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
        @keyframes slowSpinR{from{transform:rotate(0deg)}to{transform:rotate(-360deg)}}
        @keyframes dnaFloat{0%,100%{transform:translateY(0) rotateY(0deg)}50%{transform:translateY(-20px) rotateY(180deg)}}

        .anim-a{animation:floatA var(--dur,22s) ease-in-out infinite;animation-delay:var(--del,0s)}
        .anim-b{animation:floatB var(--dur,26s) ease-in-out infinite;animation-delay:var(--del,0s)}
        .anim-c{animation:floatC var(--dur,20s) ease-in-out infinite;animation-delay:var(--del,0s)}
        .anim-d{animation:floatD var(--dur,24s) ease-in-out infinite;animation-delay:var(--del,0s)}
        .anim-spin{animation:slowSpin var(--dur,40s) linear infinite;animation-delay:var(--del,0s)}
        .anim-spinr{animation:slowSpinR var(--dur,45s) linear infinite;animation-delay:var(--del,0s)}
        .anim-dna{animation:dnaFloat var(--dur,14s) ease-in-out infinite;animation-delay:var(--del,0s)}

        .glossy-shine{position:relative;overflow:hidden}
        .glossy-shine::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(ellipse at 30% 20%,rgba(255,255,255,0.3) 0%,transparent 50%);pointer-events:none}

        .reveal{opacity:0;transform:translateY(30px);filter:blur(6px);transition:all .9s cubic-bezier(.25,1,.5,1)}
        .reveal.active{opacity:1;transform:translateY(0);filter:blur(0)}

        .water-ripple{position:absolute;border-radius:50%;border:1px solid rgba(54,191,250,0.15);animation:ripple 5s ease-out infinite}
        @keyframes ripple{0%{width:0;height:0;opacity:.4}100%{width:250px;height:250px;opacity:0}}

        .gradient-text{background:linear-gradient(135deg,#026aa2,#0ba5ec,#16a34a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .nav-scrolled{background:rgba(255,255,255,0.82)!important;backdrop-filter:blur(24px) saturate(2)!important;box-shadow:0 4px 30px rgba(0,133,201,0.08)!important;border-bottom:1px solid rgba(255,255,255,0.5)!important}
        .card-hover{transition:all .5s cubic-bezier(.25,1,.5,1)}
        .card-hover:hover{transform:translateY(-6px);box-shadow:0 20px 60px rgba(0,133,201,0.12),inset 0 1px 0 rgba(255,255,255,0.8)}
        .leaf-icon{filter:drop-shadow(0 2px 8px rgba(34,197,94,0.2))}
        .counter{font-variant-numeric:tabular-nums}
        .mobile-menu{transform:translateX(100%);transition:transform .4s cubic-bezier(.25,1,.5,1)}
        .mobile-menu.open{transform:translateX(0)}
        html{scroll-behavior:smooth}
        .wave-divider{position:absolute;bottom:-1px;left:0;width:100%;overflow:hidden;line-height:0}
        .wave-divider svg{display:block;width:calc(100% + 1.3px);height:60px}
        .droplet{width:12px;height:16px;background:radial-gradient(circle at 40% 35%,rgba(255,255,255,0.9),#36bffa);border-radius:50% 50% 50% 50% / 60% 60% 40% 40%;box-shadow:0 2px 8px rgba(0,133,201,0.2)}
        .img-aero{border-radius:1.5rem;box-shadow:0 20px 60px rgba(0,133,201,0.12),0 4px 16px rgba(0,133,201,0.06)}

        ::-webkit-scrollbar{width:8px}
        ::-webkit-scrollbar-track{background:#e0f2fe}
        ::-webkit-scrollbar-thumb{background:linear-gradient(180deg,#36bffa,#0ba5ec);border-radius:999px}

        /* SVG molecule/dna styles */
        .svg-deco{fill:none;stroke:currentColor;stroke-linecap:round;stroke-linejoin:round}
    </style>
</head>
